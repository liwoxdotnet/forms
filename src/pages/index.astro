<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>Liwox Forms</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#020617;--panel:rgba(255,255,255,.06);--border:rgba(255,255,255,.12);--text:#fff;--muted:#cbd5e1;--blue:#2563eb;--cyan:#22d3ee;--violet:#8b5cf6}
*{margin:0;padding:0;box-sizing:border-box}
body{min-height:100vh;overflow:hidden;font-family:"Space Grotesk",sans-serif;color:var(--text);background:radial-gradient(circle at 15% 20%,rgba(37,99,235,.28),transparent 28%),radial-gradient(circle at 82% 25%,rgba(139,92,246,.22),transparent 30%),radial-gradient(circle at 55% 85%,rgba(34,211,238,.18),transparent 32%),#020617}
.grid{position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px);background-size:42px 42px;mask-image:radial-gradient(circle at center,black,transparent 74%);animation:drift 22s linear infinite}
.orb{position:absolute;border-radius:50%;filter:blur(90px);opacity:.42;animation:float 9s ease-in-out infinite}
.o1{width:340px;height:340px;background:var(--blue);top:5%;left:8%}
.o2{width:320px;height:320px;background:var(--violet);right:8%;bottom:10%;animation-delay:-4s}
.glow{position:fixed;width:380px;height:380px;border-radius:50%;background:radial-gradient(circle,rgba(34,211,238,.18),transparent 70%);pointer-events:none;transform:translate(-50%,-50%)}
main{display:grid;place-items:center;min-height:100vh;padding:24px;position:relative}
.hero{width:min(430px,92vw);padding:34px 28px;border-radius:28px;border:1px solid var(--border);background:var(--panel);backdrop-filter:blur(18px);text-align:center;box-shadow:0 30px 90px rgba(0,0,0,.45);z-index:2;animation:appear .9s ease}
.badge{display:inline-block;padding:8px 14px;border-radius:999px;background:rgba(37,99,235,.15);color:#bfdbfe;letter-spacing:.16em;text-transform:uppercase;font-size:11px;margin-bottom:18px}
h1{font-size:82px;line-height:.85;font-weight:800;letter-spacing:-.08em}
.brand-small{display:block;text-align:center;font-size:.34em;font-weight:500;letter-spacing:.6em;color:#dbeafe;margin-top:4px}
p{color:var(--muted);line-height:1.7;font-size:15px;margin:22px auto 30px;max-width:320px}
.btn{display:inline-flex;align-items:center;justify-content:center;min-width:165px;height:56px;border-radius:999px;background:linear-gradient(135deg,var(--blue),var(--cyan));color:#fff;text-decoration:none;font-weight:800;letter-spacing:.18em;transition:.25s;box-shadow:0 16px 48px rgba(37,99,235,.45)}
.btn:hover{transform:translateY(-3px) scale(1.04)}
footer{position:fixed;bottom:18px;width:100%;text-align:center;color:rgba(255,255,255,.45);font-size:12px;letter-spacing:.14em}
@keyframes float{50%{transform:translateY(-22px)}}@keyframes drift{to{transform:translateY(42px)}}@keyframes appear{from{opacity:0;transform:translateY(18px) scale(.98)}}
</style>
</head>
<body>
<div class="grid"></div><div class="orb o1"></div><div class="orb o2"></div><div class="glow" id="glow"></div>
<main><section class="hero"><div class="badge">Lead Capture Infrastructure</div><h1>LIWOX<span class="brand-small">FORMS</span></h1><p>Elegant lead capture experiences for every Liwox campaign, powered by Cloudflare.</p><a class="btn" href="https://liwoxgroup.com">START</a></section></main>
<footer>POWERED BY LIWOX GROUP</footer>
<script>
const glow=document.getElementById('glow');
window.addEventListener('pointermove',e=>{glow.style.left=e.clientX+'px';glow.style.top=e.clientY+'px';});
</script>
</body>
</html>
