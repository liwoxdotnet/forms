---
export const prerender = false;

import LeadForm from "../components/forms/LeadForm.astro";

const API_BASE = "https://liwox-forms-api.liwox-net.workers.dev";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Family Support Guide | Liwox Forms</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Inter, Arial, sans-serif;
    }

    body {
      min-height: 100vh;
      overflow: hidden;
      background: #071733;
      color: #fff;
    }

    .page {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      background:
        radial-gradient(circle at 18% 20%, rgba(96,165,250,.35), transparent 28%),
        radial-gradient(circle at 85% 80%, rgba(59,130,246,.22), transparent 32%),
        linear-gradient(135deg, #061327, #0b2555);
    }

    .left {
      padding: clamp(10px, 2vw, 10px);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .badge {
      width: fit-content;
      padding: 8px 13px;
      border-radius: 999px;
      background: rgba(147,197,253,.16);
      border: 1px solid rgba(191,219,254,.25);
      color: #bfdbfe;
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 22px;
    }

    h1 {
      font-size: clamp(44px, 6vw, 76px);
      line-height: .95;
      letter-spacing: -0.06em;
      max-width: 660px;
      margin-bottom: 22px;
    }

    .intro {
      color: #dbeafe;
      font-size: 19px;
      line-height: 1.55;
      max-width: 560px;
      margin-bottom: 28px;
    }

    .benefits {
      list-style: none;
      display: grid;
      gap: 14px;
      margin-bottom: 34px;
    }

    .benefits li {
      display: flex;
      align-items: center;
      gap: 12px;
      color: #eff6ff;
      font-size: 15px;
    }

    .tick {
      display: inline-grid;
      place-items: center;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      background: #60a5fa;
      color: #06203f;
      font-weight: 900;
      flex: 0 0 auto;
    }

    .product {
      width: min(420px, 90%);
      border-radius: 24px;
      padding: 24px;
      background: rgba(255,255,255,.09);
      border: 1px solid rgba(255,255,255,.16);
      box-shadow: 0 28px 80px rgba(0,0,0,.28);
      transform: rotate(-2deg);
    }

    .book {
      height: 210px;
      border-radius: 18px;
      background:
        linear-gradient(135deg, rgba(255,255,255,.22), rgba(255,255,255,.05)),
        linear-gradient(135deg, #2563eb, #22d3ee);
      padding: 26px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .book small {
      font-weight: 800;
      letter-spacing: .14em;
      color: #e0f2fe;
    }

    .book strong {
      font-size: 36px;
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .right {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: clamp(24px, 5vw, 70px);
      background: rgba(255,255,255,.92);
      color: #0f172a;
    }

    .form-wrap {
      width: min(480px, 100%);
    }

    :global(.form-panel) {
      background: #ffffff !important;
      border-radius: 24px !important;
      box-shadow: 0 30px 80px rgba(15,23,42,.18) !important;
      border: 1px solid #e5e7eb !important;
    }

    @media (max-width: 900px) {
      body {
        overflow: auto;
      }

      .page {
        grid-template-columns: 1fr;
      }

      .right {
        min-height: auto;
      }
    }
  </style>
</head>

<body>
  <main class="page">
    <section class="left">
      <div class="badge">Liwox Family Resource</div>

      <h1>Simple support for family life</h1>

      <p class="intro">
        Get a practical family resource designed to help you take the next step with clarity and confidence.
      </p>

      <div class="product">
        <div class="book">
          <small>FREE RESOURCE</small>
          <strong>Family<br />Support<br />Guide</strong>
          <small>LIWOX FORMS</small>
        </div>
      </div>
    </section>

    <section class="right">
      <div class="form-wrap">
        <LeadForm
          title="Get the Family Guide"
          description="Enter your details below."
          apiBase={API_BASE}
          campaignKey="family"
          pageKey="family"
          formKey="family-lead-form"
          source="family"
        />
      </div>
    </section>
  </main>
</body>
</html>