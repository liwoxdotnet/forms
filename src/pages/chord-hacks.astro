---
const heroImage = "https://images.unsplash.com/photo-1520523839897-bd0b52f945a0?auto=format&fit=crop&w=1200&q=80";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chord Hacks | Liwox Forms</title>
  <style>
    :root{
      --dark:#020817;--red:#f31635;--red-dark:#c8102e;--bg:#eef8ff;
      --text:#07111f;--muted:#5b6472;--line:rgba(7,17,31,.14);--card:#fff;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:Inter,Arial,Helvetica,sans-serif;background:var(--bg);color:var(--text)}
    .topbar{position:sticky;top:0;z-index:40;height:74px;background:#020817;color:#fff;display:flex;align-items:center;justify-content:space-between;padding:0 28px}
    .logo{color:#ff314d;font-weight:1000;font-size:clamp(2rem,6vw,3.2rem);letter-spacing:-.08em;line-height:1}
    .menu{width:34px;height:24px;display:grid;gap:6px;border:0;background:transparent;padding:0}
    .menu span{display:block;height:5px;border-radius:999px;background:#fff}
    .hero{max-width:780px;margin:0 auto;padding:56px 22px 42px;text-align:center}
    .headline-kicker{display:block;color:var(--red);font-size:clamp(2.4rem,10vw,4rem);font-weight:1000;text-transform:uppercase;letter-spacing:-.06em;line-height:.95}
    .headline-main{display:block;color:#050505;font-size:clamp(2rem,7vw,3rem);font-weight:1000;letter-spacing:-.05em;line-height:1.05;margin-top:4px}
    .headline-sub{margin:0;font-size:clamp(1.55rem,5.5vw,2.5rem);line-height:1.12;letter-spacing:-.04em}
    .offer-title{margin:34px 0 28px;font-size:clamp(1.35rem,5vw,2.1rem);font-weight:1000;letter-spacing:-.03em}
    .media-card{position:relative;border-radius:20px;overflow:hidden;margin:0 auto 34px;max-width:660px;box-shadow:0 20px 50px rgba(2,8,23,.16);background:#dbeafe}
    .media-card img{width:100%;display:block;aspect-ratio:4/3;object-fit:cover}
    .watch-btn{position:absolute;left:50%;bottom:34px;transform:translateX(-50%);display:inline-flex;align-items:center;gap:12px;border:0;border-radius:999px;background:#fff;color:#050505;font-weight:1000;letter-spacing:.08em;text-transform:uppercase;padding:18px 28px;font-size:1rem;box-shadow:0 12px 26px rgba(0,0,0,.18);cursor:pointer}
    .play{width:0;height:0;border-top:11px solid transparent;border-bottom:11px solid transparent;border-left:17px solid #000}
    .benefits{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin:22px 0 40px}
    .benefit{display:grid;justify-items:center;gap:10px;font-size:clamp(1.1rem,4vw,1.55rem);line-height:1.1}
    .check{width:31px;height:31px;border-radius:999px;background:var(--red);color:#fff;display:grid;place-items:center;font-weight:1000}
    .intro-copy{font-size:clamp(1.25rem,4.3vw,2rem);line-height:1.45;margin:0 auto 30px;max-width:700px}
    .signup{display:grid;gap:18px;margin:0 auto 30px;max-width:680px}
    .email-input{height:84px;width:100%;border-radius:999px;border:2px solid rgba(7,17,31,.45);background:#edf5ff;padding:0 34px;font-size:clamp(1.4rem,5vw,2.2rem);text-align:center;outline:none}
    .email-input:focus{border-color:var(--red);box-shadow:0 0 0 4px rgba(243,22,53,.13)}
    .primary-btn{height:84px;border:0;border-radius:999px;background:var(--red);color:#fff;font-size:clamp(1.15rem,4vw,1.6rem);font-weight:1000;letter-spacing:-.03em;text-transform:uppercase;cursor:pointer;box-shadow:0 12px 28px rgba(243,22,53,.25)}
    .primary-btn:hover{background:var(--red-dark)}
    .small-note{color:var(--muted);font-size:clamp(1rem,3.5vw,1.35rem);margin:0 0 46px}
    .details-card{max-width:680px;margin:0 auto 30px;border:1px solid var(--line);border-radius:16px;background:rgba(255,255,255,.35);padding:30px 32px;text-align:left}
    .detail{display:grid;grid-template-columns:52px 1fr;gap:18px;align-items:start;margin:0 0 26px}
    .detail:last-child{margin-bottom:0}
    .detail-icon{color:var(--red);font-size:2rem;line-height:1}
    .detail strong{display:block;font-size:clamp(1.25rem,4vw,1.65rem);margin-bottom:4px}
    .detail span{color:#111827;font-size:clamp(1.05rem,3.8vw,1.35rem)}
    .italic-note{color:#6b7280;font-size:clamp(1.12rem,4vw,1.45rem);line-height:1.5;font-style:italic;margin:26px auto 52px}
    .dark-band{background:linear-gradient(180deg,#0b0b0c,#1b1b1f);color:#fff;padding:44px 24px;text-align:center;font-size:clamp(1.7rem,6vw,3rem);font-weight:1000;letter-spacing:-.05em}
    .chat-bubble{position:fixed;right:22px;bottom:24px;z-index:45;width:86px;height:86px;border-radius:28px;border:0;background:var(--red);color:#fff;display:grid;place-items:center;font-size:2.3rem;box-shadow:0 16px 36px rgba(2,8,23,.24);cursor:pointer}
    .cookie{position:fixed;left:12px;right:12px;bottom:16px;z-index:60;background:#fff;border-radius:14px;box-shadow:0 16px 40px rgba(2,8,23,.25);padding:18px 16px;display:none;align-items:center;justify-content:space-between;gap:14px;font-size:1.1rem}
    .cookie.show{display:flex}
    .cookie a{color:var(--red);text-decoration:none;font-weight:800}
    .cookie button{border:0;background:var(--red);color:#fff;border-radius:999px;padding:15px 26px;font-weight:1000;text-transform:uppercase;white-space:nowrap;cursor:pointer}
    .modal-backdrop{position:fixed;inset:0;z-index:70;background:rgba(46,0,12,.48);display:none;align-items:center;justify-content:center;padding:22px}
    .modal-backdrop.show{display:flex}
    .modal{position:relative;width:min(610px,100%);max-height:88vh;overflow:auto;background:#fff;border-radius:34px;padding:36px 32px 28px;box-shadow:0 25px 80px rgba(2,8,23,.35)}
    .modal-close{position:absolute;top:28px;right:28px;border:0;background:transparent;color:var(--red);font-size:2.1rem;font-weight:1000;cursor:pointer}
    .modal h2{margin:0 0 24px;color:var(--red);font-size:clamp(2.2rem,9vw,3rem);line-height:1;font-weight:1000;letter-spacing:.03em;text-transform:uppercase}
    .modal p{font-size:clamp(1.15rem,4vw,1.55rem);line-height:1.45;margin:0 0 18px}
    .modal strong{font-weight:1000}
    .modal-form{display:grid;gap:16px;margin-top:26px}
    .modal-input{height:74px;border-radius:999px;border:1.5px solid #cfd5dd;padding:0 28px;font-size:1.4rem;outline:none}
    .privacy{display:grid;grid-template-columns:28px 1fr;gap:12px;color:#555;font-size:1.05rem;line-height:1.25;margin-top:12px}
    .info-dot{width:28px;height:28px;border-radius:999px;border:2px solid #555;display:grid;place-items:center;font-weight:900}
    @media(max-width:560px){
      .topbar{height:72px;padding:0 18px}.hero{padding-top:44px}.media-card{border-radius:16px}
      .watch-btn{padding:15px 20px;bottom:24px;font-size:.9rem}.email-input,.primary-btn{height:72px}
      .details-card{padding:26px 22px}.detail{grid-template-columns:44px 1fr}.modal{border-radius:30px;padding:32px 28px 24px}
      .cookie{font-size:1rem}.cookie button{padding:14px 20px}
    }
  </style>
</head>

<body>
  <header class="topbar">
    <div class="logo">MusicVibe</div>
    <button class="menu" type="button" aria-label="Open menu"><span></span><span></span><span></span></button>
  </header>

  <main class="hero">
    <h1>
      <span class="headline-kicker">Chord Hacks</span>
      <span class="headline-main">The easiest way to</span>
      <span class="headline-sub">learn beautiful piano chords.</span>
    </h1>

    <p class="offer-title">Sign up for 5 FREE play-along lessons</p>

    <section class="media-card" aria-label="Course trailer">
      <iframe
      src="https://www.youtube.com/watch?v=bV76VvX-DhQ"
      title="Course trailer"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      ></iframe>
      <button class="watch-btn" type="button"><span class="play"></span>Watch Trailer</button>
    </section>

    <section class="benefits">
      <div class="benefit"><span class="check">✓</span><span>Learn<br />by doing</span></div>
      <div class="benefit"><span class="check">✓</span><span>No theory<br />required</span></div>
      <div class="benefit"><span class="check">✓</span><span>Free lifetime<br />access</span></div>
    </section>

    <p class="intro-copy">Create a free account to access your Chord Hacks lessons and browse thousands more while you're in there.</p>

    <form id="mainForm" class="signup">
      <input id="mainEmail" class="email-input" type="email" name="email" placeholder="Your Email" autocomplete="email" required />
      <button class="primary-btn" type="submit">Get My Free Lessons ✈</button>
    </form>

    <p class="small-note">Free account. No credit card required.</p>

    <section class="details-card">
      <div class="detail"><div class="detail-icon">▣</div><div><strong>Course Dates</strong><span>Start anytime!</span></div></div>
      <div class="detail"><div class="detail-icon">◷</div><div><strong>Commitment</strong><span>10 minutes a day for just 5 days.</span></div></div>
      <div class="detail"><div class="detail-icon">▤</div><div><strong>Skill Level</strong><span>Beginner.</span></div></div>
      <div class="detail"><div class="detail-icon">♕</div><div><strong>Result</strong><span>Play your first song.</span></div></div>
    </section>

    <p class="italic-note">Flexible lesson times to fit any schedule<br />PLUS you get lifetime access!</p>
  </main>

  <section class="dark-band">Play beautiful piano in minutes, not months.</section>

  <button id="chatButton" class="chat-bubble" type="button" aria-label="Open chat">♡</button>

  <div id="cookieBanner" class="cookie">
    <span>We use cookies for traffic data and advertising. <a href="#">Cookie Policy »</a></span>
    <button id="acceptCookies" type="button">Okay Got It</button>
  </div>

  <div id="exitModal" class="modal-backdrop" role="dialog" aria-modal="true" aria-label="Exit offer">
    <div class="modal">
      <button id="closeModal" class="modal-close" type="button" aria-label="Close popup">×</button>
      <h2>Hold Up!</h2>
      <p>Not ready for video lessons?</p>
      <p><strong>Grab the Little Book of Chord Progressions to learn the most popular chord progressions used in modern music.</strong></p>
      <p>No credit card. No spam.</p>
      <p>Just awesome chords to get you playing.</p>

      <form id="popupForm" class="modal-form">
        <input id="popupEmail" class="modal-input" type="email" name="email" placeholder="Your Email" autocomplete="email" required />
        <button class="primary-btn" type="submit">Get My E-Book ✈</button>
      </form>

      <div class="privacy">
        <span class="info-dot">i</span>
        <span>By signing up, you'll also receive ongoing free lessons, tips, and special offers. Don't worry, we value your privacy and you can unsubscribe at any time.</span>
      </div>
    </div>
  </div>

  <script>
    const API_BASE = "https://liwox-forms-api.liwox-net.workers.dev";
    const cookieBanner = document.getElementById("cookieBanner");
    const acceptCookies = document.getElementById("acceptCookies");
    const exitModal = document.getElementById("exitModal");
    const closeModal = document.getElementById("closeModal");
    const mainForm = document.getElementById("mainForm");
    const popupForm = document.getElementById("popupForm");
    const mainEmail = document.getElementById("mainEmail");
    const popupEmail = document.getElementById("popupEmail");
    let popupShown = false;

    function showCookieBanner(){ if(!localStorage.getItem("liwox_cookie_ok")) cookieBanner.classList.add("show"); }
    function hideCookieBanner(){ localStorage.setItem("liwox_cookie_ok","yes"); cookieBanner.classList.remove("show"); }
    function showExitModal(){ if(popupShown) return; popupShown = true; exitModal.classList.add("show"); }
    function hideExitModal(){ exitModal.classList.remove("show"); }

    async function submitLead(email, source){
      const response = await fetch(`${API_BASE}/api/leads`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email,
          full_name: "",
          phone: "",
          company: "",
          message: source === "popup" ? "Requested Chord Progressions E-Book" : "Requested Free Chord Hacks Lessons",
          source,
          campaign_key: "chord-hacks",
          page_key: "chord-hacks",
          form_key: source === "popup" ? "chord-hacks-popup" : "chord-hacks-main",
          utm_source: new URLSearchParams(window.location.search).get("utm_source") || "",
          utm_medium: new URLSearchParams(window.location.search).get("utm_medium") || "",
          utm_campaign: new URLSearchParams(window.location.search).get("utm_campaign") || ""
        })
      });

      const data = await response.json();
      if(!data.success) throw new Error(data.error || "Unable to submit form");
      window.location.href = `/confirm?email=${encodeURIComponent(email)}`;
    }

    mainForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const email = mainEmail.value.trim();
      if(!email) return;
      const button = mainForm.querySelector("button");
      button.disabled = true;
      button.textContent = "Sending...";
      try { await submitLead(email, "main_form"); }
      catch(error){ alert(error.message || "Unable to submit form"); button.disabled = false; button.textContent = "Get My Free Lessons ✈"; }
    });

    popupForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const email = popupEmail.value.trim();
      if(!email) return;
      const button = popupForm.querySelector("button");
      button.disabled = true;
      button.textContent = "Sending...";
      try { await submitLead(email, "popup"); }
      catch(error){ alert(error.message || "Unable to submit form"); button.disabled = false; button.textContent = "Get My E-Book ✈"; }
    });

    acceptCookies.addEventListener("click", hideCookieBanner);
    closeModal.addEventListener("click", hideExitModal);
    exitModal.addEventListener("click", (event) => { if(event.target === exitModal) hideExitModal(); });

    document.addEventListener("mouseleave", (event) => { if(event.clientY <= 0) showExitModal(); });

    let lastScrollY = 0;
    window.addEventListener("scroll", () => {
      const currentY = window.scrollY;
      const scrollPercent = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
      if(currentY < lastScrollY && scrollPercent > .45) showExitModal();
      lastScrollY = currentY;
    }, { passive: true });

    setTimeout(() => { if(!popupShown) showExitModal(); }, 22000);
    showCookieBanner();
  </script>
</body>
</html>
