---
export const prerender = false;

import LandingLayout from "../components/layouts/LandingLayout.astro";
import Hero from "../components/landing/Hero.astro";
import LeadForm from "../components/forms/LeadForm.astro";

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join("/") : slugParam || "default";

const API_BASE = "https://liwox-forms-api.liwox-net.workers.dev";

let pageConfig = {
  slug,
  page_key: slug,
  title: "Register Your Interest",
  description: "Complete the short form and our team will contact you with the next step.",
  campaign_key: slug,
  campaign_name: "Liwox Campaign",
  form_key: "",
  form_name: "Apply Now"
};

try {
  const response = await fetch(`${API_BASE}/api/pages/${slug}`);
  const data = await response.json();

  if (data.success && data.page) {
    pageConfig = {
      ...pageConfig,
      slug: data.page.slug || slug,
      page_key: data.page.page_key || slug,
      title: data.page.title || pageConfig.title,
      description: data.page.description || pageConfig.description,
      campaign_key: data.page.campaign_key || slug,
      campaign_name: data.page.campaign_name || "Liwox Campaign",
      form_key: data.page.form_key || "",
      form_name: data.page.form_name || "Apply Now"
    };
  }
} catch (error) {
  // If API page config is unavailable, the page still works with fallback content.
}
---

<LandingLayout
  title={pageConfig.title}
  description={pageConfig.description}
>
  <main class="landing-page">
    <Hero
      badge={pageConfig.campaign_name}
      title={pageConfig.title}
      description={pageConfig.description}
    />

    <LeadForm
      title={pageConfig.form_name}
      description="Enter your details below."
      apiBase={API_BASE}
      campaignKey={pageConfig.campaign_key}
      pageKey={pageConfig.page_key}
      formKey={pageConfig.form_key}
      source={slug}
    />
  </main>
</LandingLayout>

<style>
  .landing-page {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 460px;
  }

  @media (max-width: 900px) {
    .landing-page {
      grid-template-columns: 1fr;
    }
  }
</style>
