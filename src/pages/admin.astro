---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Liwox Forms Admin</title>

  <style>
    :root {
      --bg: #f4f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --navy: #06142f;
      --blue: #2563eb;
      --green: #16a34a;
      --radius: 16px;
      --shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
      --font: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
    }

    .layout {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 260px 1fr;
    }

    .sidebar {
      background: var(--navy);
      color: #fff;
      padding: 24px 20px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 36px;
    }

    .brand-mark {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      background: linear-gradient(135deg, #3b82f6, #60a5fa);
    }

    .brand h1 {
      font-size: 1.1rem;
      margin: 0;
      line-height: 1.1;
    }

    .brand p {
      margin: 4px 0 0;
      color: #cbd5e1;
      font-size: 0.8rem;
    }

    .nav {
      display: grid;
      gap: 8px;
    }

    .nav a {
      color: #dbeafe;
      text-decoration: none;
      padding: 12px 14px;
      border-radius: 12px;
      font-weight: 700;
      font-size: 0.95rem;
    }

    .nav a.active,
    .nav a:hover {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
    }

    .main { padding: 28px; }

    .topbar {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: flex-start;
      margin-bottom: 24px;
    }

    .topbar h2 {
      margin: 0;
      font-size: clamp(1.8rem, 4vw, 2.5rem);
      letter-spacing: -0.04em;
    }

    .topbar p {
      margin: 8px 0 0;
      color: var(--muted);
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    button,
    .button {
      border: 0;
      background: var(--blue);
      color: #fff;
      font-weight: 800;
      padding: 12px 16px;
      border-radius: 12px;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
    }

    button.secondary {
      background: #e5e7eb;
      color: #111827;
    }

    button.green { background: var(--green); }

    .cards {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 22px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: var(--shadow);
    }

    .stat-label {
      color: var(--muted);
      font-size: 0.88rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .stat-value {
      font-size: 2rem;
      font-weight: 900;
      margin-top: 8px;
      letter-spacing: -0.04em;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 18px;
      align-items: start;
    }

    .section-title {
      margin: 0 0 16px;
      font-size: 1.25rem;
    }

    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 820px;
    }

    th, td {
      padding: 13px 12px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      font-size: 0.92rem;
      vertical-align: top;
    }

    th {
      color: #374151;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      background: #f9fafb;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      padding: 5px 10px;
      border-radius: 999px;
      background: #e0f2fe;
      color: #075985;
      font-weight: 800;
      font-size: 0.78rem;
    }

    .pill.new {
      background: #dcfce7;
      color: #166534;
    }

    .pill.empty {
      background: #f3f4f6;
      color: #6b7280;
    }

    .field {
      width: 100%;
      padding: 13px 14px;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      font: inherit;
      background: #fff;
    }

    textarea.field {
      min-height: 92px;
      resize: vertical;
    }

    .form {
      display: grid;
      gap: 12px;
    }

    .message {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 12px;
      display: none;
      font-weight: 700;
    }

    .message.ok {
      display: block;
      background: #dcfce7;
      color: #166534;
    }

    .message.error {
      display: block;
      background: #fee2e2;
      color: #991b1b;
    }

    .empty-state {
      color: var(--muted);
      padding: 20px;
      text-align: center;
    }

    @media (max-width: 980px) {
      .layout { grid-template-columns: 1fr; }
      .cards, .grid { grid-template-columns: 1fr; }
      .topbar { flex-direction: column; }
    }
  </style>
</head>

<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-mark"></div>
        <div>
          <h1>Liwox Forms</h1>
          <p>Admin Dashboard</p>
        </div>
      </div>

      <nav class="nav">
        <a href="/admin" class="active">Dashboard</a>
        <a href="/candidate">Candidate Page</a>
        <a href="http://127.0.0.1:8787/api/leads" target="_blank">API Leads</a>
        <a href="http://127.0.0.1:8787/api/campaigns" target="_blank">API Campaigns</a>
      </nav>
    </aside>

    <main class="main">
      <div class="topbar">
        <div>
          <h2>Dashboard</h2>
          <p>View leads, campaigns, and form activity from Liwox landing pages.</p>
        </div>

        <div class="actions">
          <button id="refreshBtn">Refresh</button>
          <button id="exportBtn" class="secondary">Export CSV</button>
        </div>
      </div>

      <section class="cards">
        <div class="card">
          <div class="stat-label">Total Leads</div>
          <div class="stat-value" id="totalLeads">0</div>
        </div>

        <div class="card">
          <div class="stat-label">Today's Leads</div>
          <div class="stat-value" id="todaysLeads">0</div>
        </div>

        <div class="card">
          <div class="stat-label">New Leads</div>
          <div class="stat-value" id="newLeads">0</div>
        </div>

        <div class="card">
          <div class="stat-label">Campaigns</div>
          <div class="stat-value" id="campaignCount">0</div>
        </div>
      </section>

      <section class="grid">
        <div class="card">
          <h3 class="section-title">Recent Leads</h3>

          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Full Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Campaign</th>
                  <th>Source</th>
                  <th>Status</th>
                  <th>Created</th>
                </tr>
              </thead>
              <tbody id="leadsTable">
                <tr>
                  <td colspan="8" class="empty-state">Loading leads...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <div class="card" style="margin-bottom: 18px;">
            <h3 class="section-title">Create Campaign</h3>

            <form id="campaignForm" class="form">
              <input class="field" name="name" placeholder="Campaign Name" required />
              <input class="field" name="campaign_key" placeholder="campaign-key" required />
              <textarea class="field" name="description" placeholder="Description"></textarea>
              <button class="green" type="submit">Create Campaign</button>
            </form>

            <div id="campaignMessage" class="message"></div>
          </div>

          <div class="card">
            <h3 class="section-title">Campaigns</h3>

            <div class="table-wrap">
              <table style="min-width: 420px;">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Key</th>
                    <th>Leads</th>
                  </tr>
                </thead>
                <tbody id="campaignsTable">
                  <tr>
                    <td colspan="3" class="empty-state">Loading campaigns...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    const API_BASE = "http://127.0.0.1:8787";

    const state = {
      leads: [],
      campaigns: []
    };

    const totalLeads = document.getElementById("totalLeads");
    const todaysLeads = document.getElementById("todaysLeads");
    const newLeads = document.getElementById("newLeads");
    const campaignCount = document.getElementById("campaignCount");
    const leadsTable = document.getElementById("leadsTable");
    const campaignsTable = document.getElementById("campaignsTable");
    const refreshBtn = document.getElementById("refreshBtn");
    const exportBtn = document.getElementById("exportBtn");
    const campaignForm = document.getElementById("campaignForm");
    const campaignMessage = document.getElementById("campaignMessage");

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function showMessage(element, text, type) {
      element.className = `message ${type}`;
      element.textContent = text;

      setTimeout(() => {
        element.className = "message";
        element.textContent = "";
      }, 5000);
    }

    function formatDate(value) {
      if (!value) return "";
      try {
        return new Date(value).toLocaleString();
      } catch {
        return value;
      }
    }

    function updateStats() {
      const today = new Date().toISOString().slice(0, 10);

      totalLeads.textContent = String(state.leads.length);
      todaysLeads.textContent = String(
        state.leads.filter((lead) => String(lead.created_at || "").slice(0, 10) === today).length
      );
      newLeads.textContent = String(
        state.leads.filter((lead) => lead.status === "new").length
      );
      campaignCount.textContent = String(state.campaigns.length);
    }

    function renderLeads() {
      if (!state.leads.length) {
        leadsTable.innerHTML = `
          <tr>
            <td colspan="8" class="empty-state">No leads yet</td>
          </tr>
        `;
        return;
      }

      leadsTable.innerHTML = state.leads.map((lead) => `
        <tr>
          <td>${escapeHtml(lead.id)}</td>
          <td><strong>${escapeHtml(lead.full_name)}</strong></td>
          <td>${escapeHtml(lead.email)}</td>
          <td>${escapeHtml(lead.phone)}</td>
          <td>${lead.campaign_name ? escapeHtml(lead.campaign_name) : '<span class="pill empty">No campaign</span>'}</td>
          <td>${escapeHtml(lead.source)}</td>
          <td><span class="pill ${lead.status === "new" ? "new" : ""}">${escapeHtml(lead.status)}</span></td>
          <td>${escapeHtml(formatDate(lead.created_at))}</td>
        </tr>
      `).join("");
    }

    function renderCampaigns() {
      if (!state.campaigns.length) {
        campaignsTable.innerHTML = `
          <tr>
            <td colspan="3" class="empty-state">No campaigns yet</td>
          </tr>
        `;
        return;
      }

      campaignsTable.innerHTML = state.campaigns.map((campaign) => `
        <tr>
          <td><strong>${escapeHtml(campaign.name)}</strong></td>
          <td><span class="pill">${escapeHtml(campaign.campaign_key)}</span></td>
          <td>${escapeHtml(campaign.lead_count ?? 0)}</td>
        </tr>
      `).join("");
    }

    async function fetchJson(url) {
      const response = await fetch(url);
      const data = await response.json();

      if (!data.success) {
        throw new Error(data.error || "API request failed");
      }

      return data;
    }

    async function loadDashboard() {
      refreshBtn.textContent = "Loading...";
      refreshBtn.disabled = true;

      try {
        const [leadsData, campaignsData] = await Promise.all([
          fetchJson(`${API_BASE}/api/leads`),
          fetchJson(`${API_BASE}/api/campaigns`)
        ]);

        state.leads = leadsData.leads || [];
        state.campaigns = campaignsData.campaigns || [];

        updateStats();
        renderLeads();
        renderCampaigns();
      } catch (error) {
        leadsTable.innerHTML = `
          <tr>
            <td colspan="8" class="empty-state">Error loading data: ${escapeHtml(error.message)}</td>
          </tr>
        `;
      } finally {
        refreshBtn.textContent = "Refresh";
        refreshBtn.disabled = false;
      }
    }

    function exportCsv() {
      if (!state.leads.length) {
        alert("No leads to export.");
        return;
      }

      const headers = [
        "id",
        "full_name",
        "email",
        "phone",
        "campaign_name",
        "source",
        "status",
        "created_at"
      ];

      const rows = state.leads.map((lead) =>
        headers.map((header) => {
          const value = String(lead[header] ?? "").replaceAll('"', '""');
          return `"${value}"`;
        }).join(",")
      );

      const csv = [headers.join(","), ...rows].join("\n");
      const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");

      link.href = url;
      link.download = `liwox-leads-${new Date().toISOString().slice(0, 10)}.csv`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    campaignForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const formData = new FormData(campaignForm);
      const payload = {
        name: formData.get("name"),
        campaign_key: formData.get("campaign_key"),
        description: formData.get("description"),
        status: "active"
      };

      try {
        const response = await fetch(`${API_BASE}/api/campaigns`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (!data.success) {
          throw new Error(data.error || "Unable to create campaign");
        }

        campaignForm.reset();
        showMessage(campaignMessage, "Campaign created successfully.", "ok");
        await loadDashboard();
      } catch (error) {
        showMessage(campaignMessage, error.message, "error");
      }
    });

    refreshBtn.addEventListener("click", loadDashboard);
    exportBtn.addEventListener("click", exportCsv);

    loadDashboard();
  </script>
</body>
</html>
