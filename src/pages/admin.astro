---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Liwox Forms Admin</title>
</head>

<body>
  <h1>Liwox Forms Admin</h1>
  <p>Leads captured from landing pages will appear below.</p>

  <button id="refreshBtn">Refresh Leads</button>

  <br><br>

  <table border="1" cellpadding="10" cellspacing="0">
    <thead>
      <tr>
        <th>ID</th>
        <th>Full Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Source</th>
        <th>Status</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody id="leadsTable">
      <tr>
        <td colspan="7">Loading leads...</td>
      </tr>
    </tbody>
  </table>

  <script>
    const API_URL = "http://127.0.0.1:8787/api/leads";
    const table = document.getElementById("leadsTable");
    const refreshBtn = document.getElementById("refreshBtn");

    async function loadLeads() {
      table.innerHTML = `
        <tr>
          <td colspan="7">Loading leads...</td>
        </tr>
      `;

      try {
        const response = await fetch(API_URL);
        const result = await response.json();

        if (!result.success) {
          table.innerHTML = `
            <tr>
              <td colspan="7">Failed to load leads</td>
            </tr>
          `;
          return;
        }

        if (!result.leads || result.leads.length === 0) {
          table.innerHTML = `
            <tr>
              <td colspan="7">No leads yet</td>
            </tr>
          `;
          return;
        }

        table.innerHTML = result.leads.map((lead) => `
          <tr>
            <td>${lead.id ?? ""}</td>
            <td>${lead.full_name ?? ""}</td>
            <td>${lead.email ?? ""}</td>
            <td>${lead.phone ?? ""}</td>
            <td>${lead.source ?? ""}</td>
            <td>${lead.status ?? ""}</td>
            <td>${lead.created_at ?? ""}</td>
          </tr>
        `).join("");

      } catch (error) {
        table.innerHTML = `
          <tr>
            <td colspan="7">Error connecting to API</td>
          </tr>
        `;
      }
    }

    refreshBtn.addEventListener("click", loadLeads);

    loadLeads();
  </script>
</body>
</html>