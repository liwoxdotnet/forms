---
import AdminLayout from "../components/layouts/AdminLayout.astro";
import PageHeader from "../components/admin/PageHeader.astro";
import DashboardGrid from "../components/admin/DashboardGrid.astro";
import DashboardSection from "../components/admin/DashboardSection.astro";
import Toast from "../components/shared/Toast.astro";
---

<AdminLayout title="Liwox Forms Admin" active="dashboard">
  <Toast />

  <section id="loginView" class="auth-shell">
    <div class="auth-card">
      <div class="auth-badge">Restricted Area</div>
      <h1>Liwox Forms Admin</h1>
      <p>Enter your approved admin email address. We will send you a secure login link.</p>

      <form id="loginForm" class="auth-form">
        <input id="adminEmail" type="email" placeholder="Admin email address" required />
        <button id="loginBtn" type="submit">Send Login Link</button>
      </form>

      <div id="loginMessage" class="auth-message"></div>
    </div>
  </section>

  <section id="dashboardView" class="dashboard-hidden">
    <button id="sidebarLogoutBtn" type="button" class="sidebar-logout-btn">
      Logout
    </button>

    <div class="admin-topline">
      <PageHeader
        title="Dashboard"
        description="View leads, campaigns, pages, and forms from Liwox landing pages."
      />

      <button id="logoutBtn" type="button" class="logout-btn">Logout</button>
    </div>

    <section class="kpi-grid">
      <div class="metric-card">
        <p>Total Leads</p>
        <strong id="totalLeads">0</strong>
      </div>

      <div class="metric-card">
        <p>Today's Leads</p>
        <strong id="todaysLeads">0</strong>
      </div>

      <div class="metric-card">
        <p>New Leads</p>
        <strong id="newLeads">0</strong>
      </div>

      <div class="metric-card">
        <p>Campaigns</p>
        <strong id="campaignCount">0</strong>
      </div>
    </section>

    <div class="toolbar">
      <div class="search-box">
        <span>⌕</span>
        <input id="searchInput" type="search" placeholder="Search leads by name, email, phone, campaign..." />
      </div>

      <select id="statusFilter">
        <option value="all">All statuses</option>
        <option value="new">New</option>
        <option value="contacted">Contacted</option>
        <option value="qualified">Qualified</option>
        <option value="archived">Archived</option>
      </select>

      <button id="refreshBtn" type="button">Refresh</button>
      <button id="exportBtn" type="button" class="secondary">Export CSV</button>
    </div>

    <DashboardGrid columns={2}>
      <DashboardSection title="Recent Leads" description="Latest leads captured from all landing pages.">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Campaign</th>
                <th>Source</th>
                <th>Status</th>
                <th>Created</th>
              </tr>
            </thead>
            <tbody id="leadsTable">
              <tr>
                <td colspan="8" class="empty">Loading leads...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </DashboardSection>

      <div class="side-stack">
        <DashboardSection title="Create Campaign" description="Create a campaign for tracking landing page leads.">
          <form id="campaignForm" class="form-grid">
            <input class="field" name="name" placeholder="Campaign Name" required />
            <input class="field" name="campaign_key" placeholder="campaign-key" required />
            <textarea class="field" name="description" placeholder="Description"></textarea>
            <button type="submit">Create Campaign</button>
          </form>
        </DashboardSection>

        <DashboardSection title="Create Landing Page" description="Create a page record that dynamic routes can load.">
          <form id="pageForm" class="form-grid">
            <input class="field" name="title" placeholder="Page Title" required />
            <input class="field" name="slug" placeholder="page-slug" required />
            <input class="field" name="campaign_key" placeholder="campaign-key" required />
            <button type="submit">Create Page</button>
          </form>
        </DashboardSection>

        <DashboardSection title="Campaigns">
          <div class="table-wrap small">
            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Key</th>
                  <th>Leads</th>
                </tr>
              </thead>
              <tbody id="campaignsTable">
                <tr>
                  <td colspan="3" class="empty">Loading campaigns...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </DashboardSection>

        <DashboardSection title="Pages">
          <div class="table-wrap small">
            <table>
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Slug</th>
                  <th>Leads</th>
                </tr>
              </thead>
              <tbody id="pagesTable">
                <tr>
                  <td colspan="3" class="empty">Loading pages...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </DashboardSection>
      </div>
    </DashboardGrid>
  </section>

  <script>
    const API_BASE = "https://liwox-forms-api.liwox-net.workers.dev";
    const ADMIN_TOKEN_KEY = "liwox_admin_token";

    const loginView = document.getElementById("loginView");
    const dashboardView = document.getElementById("dashboardView");
    const loginForm = document.getElementById("loginForm");
    const adminEmail = document.getElementById("adminEmail");
    const loginBtn = document.getElementById("loginBtn");
    const loginMessage = document.getElementById("loginMessage");
    const logoutBtn = document.getElementById("logoutBtn");
    const sidebarLogoutBtn = document.getElementById("sidebarLogoutBtn");

    const state = {
      token: "",
      leads: [],
      filteredLeads: [],
      campaigns: [],
      pages: []
    };

    const totalLeads = document.getElementById("totalLeads");
    const todaysLeads = document.getElementById("todaysLeads");
    const newLeads = document.getElementById("newLeads");
    const campaignCount = document.getElementById("campaignCount");

    const leadsTable = document.getElementById("leadsTable");
    const campaignsTable = document.getElementById("campaignsTable");
    const pagesTable = document.getElementById("pagesTable");

    const refreshBtn = document.getElementById("refreshBtn");
    const exportBtn = document.getElementById("exportBtn");
    const searchInput = document.getElementById("searchInput");
    const statusFilter = document.getElementById("statusFilter");

    const campaignForm = document.getElementById("campaignForm");
    const pageForm = document.getElementById("pageForm");

    function toast(message, type = "success") {
      if (window.LiwoxToast) {
        window.LiwoxToast(message, type);
      } else {
        alert(message);
      }
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function formatDate(value) {
      if (!value) return "";
      try {
        return new Date(value).toLocaleString();
      } catch {
        return value;
      }
    }

    function statusBadge(status) {
      const value = status || "new";
      const normalized = String(value).toLowerCase();
      return `<span class="status-badge status-${escapeHtml(normalized)}">${escapeHtml(value)}</span>`;
    }

    function getAuthHeaders() {
      const headers = { "Content-Type": "application/json" };

      if (state.token) {
        headers.Authorization = `Bearer ${state.token}`;
      }

      return headers;
    }

    async function fetchJson(url, options = {}) {
      const response = await fetch(url, {
        ...options,
        headers: {
          ...(options.headers || {}),
          ...(state.token ? { Authorization: `Bearer ${state.token}` } : {})
        }
      });

      const data = await response.json();

      if (!data.success) {
        throw new Error(data.error || "API request failed");
      }

      return data;
    }

    function showLogin(message = "") {
      dashboardView.classList.add("dashboard-hidden");
      loginView.classList.remove("auth-hidden");

      if (message) {
        loginMessage.className = "auth-message error";
        loginMessage.textContent = message;
      }
    }

    function showDashboard() {
      loginView.classList.add("auth-hidden");
      dashboardView.classList.remove("dashboard-hidden");
    }

    function readTokenFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const token = params.get("admin_token");

      if (token) {
        localStorage.setItem(ADMIN_TOKEN_KEY, token);
        window.history.replaceState({}, document.title, "/admin");
      }

      return token;
    }

    async function checkSession() {
      const tokenFromUrl = readTokenFromUrl();
      state.token = tokenFromUrl || localStorage.getItem(ADMIN_TOKEN_KEY) || "";

      if (!state.token) {
        showLogin();
        return;
      }

      try {
        await fetchJson(`${API_BASE}/api/admin/session`);
        showDashboard();
        await loadDashboard();
      } catch (error) {
        localStorage.removeItem(ADMIN_TOKEN_KEY);
        state.token = "";
        showLogin("Your admin session has expired. Request a new login link.");
      }
    }

    async function logoutAdmin() {
      try {
        await fetch(`${API_BASE}/api/admin/logout`, {
          method: "POST",
          headers: getAuthHeaders()
        });
      } catch {
        // Continue local logout even if the API logout request fails.
      }

      localStorage.removeItem(ADMIN_TOKEN_KEY);
      state.token = "";
      showLogin("You have been logged out.");
    }

    loginForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const email = adminEmail.value.trim();
      if (!email) return;

      loginBtn.disabled = true;
      loginBtn.textContent = "Sending...";
      loginMessage.className = "auth-message";
      loginMessage.textContent = "";

      try {
        const response = await fetch(`${API_BASE}/api/admin/send-login-link`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email })
        });

        const data = await response.json();

        if (!data.success) {
          throw new Error(data.error || "Unable to send login link");
        }

        loginMessage.className = "auth-message success";

        if (data.login_url) {
          loginMessage.innerHTML = `
            Login link generated. Email sending is not configured yet.<br />
            <a href="${escapeHtml(data.login_url)}">Open secure login link</a>
          `;
        } else {
          loginMessage.textContent = "Login link sent. Check your email.";
        }
      } catch (error) {
        loginMessage.className = "auth-message error";
        loginMessage.textContent = error.message || "Unable to send login link";
      } finally {
        loginBtn.disabled = false;
        loginBtn.textContent = "Send Login Link";
      }
    });

    logoutBtn.addEventListener("click", logoutAdmin);
    sidebarLogoutBtn.addEventListener("click", logoutAdmin);

    function updateStats() {
      const today = new Date().toISOString().slice(0, 10);

      totalLeads.textContent = String(state.leads.length);
      todaysLeads.textContent = String(
        state.leads.filter((lead) => String(lead.created_at || "").slice(0, 10) === today).length
      );
      newLeads.textContent = String(
        state.leads.filter((lead) => lead.status === "new").length
      );
      campaignCount.textContent = String(state.campaigns.length);
    }

    function applyFilters() {
      const query = String(searchInput.value || "").toLowerCase().trim();
      const status = statusFilter.value;

      state.filteredLeads = state.leads.filter((lead) => {
        const haystack = [
          lead.full_name,
          lead.email,
          lead.phone,
          lead.campaign_name,
          lead.source,
          lead.status
        ].join(" ").toLowerCase();

        const matchesQuery = !query || haystack.includes(query);
        const matchesStatus = status === "all" || lead.status === status;

        return matchesQuery && matchesStatus;
      });

      renderLeads();
    }

    function renderLeads() {
      if (!state.filteredLeads.length) {
        leadsTable.innerHTML = `<tr><td colspan="8" class="empty">No leads found</td></tr>`;
        return;
      }

      leadsTable.innerHTML = state.filteredLeads.map((lead) => `
        <tr>
          <td>${escapeHtml(lead.id)}</td>
          <td><strong>${escapeHtml(lead.full_name)}</strong></td>
          <td>${escapeHtml(lead.email)}</td>
          <td>${escapeHtml(lead.phone)}</td>
          <td>${lead.campaign_name ? escapeHtml(lead.campaign_name) : "—"}</td>
          <td>${escapeHtml(lead.source)}</td>
          <td>${statusBadge(lead.status)}</td>
          <td>${escapeHtml(formatDate(lead.created_at))}</td>
        </tr>
      `).join("");
    }

    function renderCampaigns() {
      if (!state.campaigns.length) {
        campaignsTable.innerHTML = `<tr><td colspan="3" class="empty">No campaigns yet</td></tr>`;
        return;
      }

      campaignsTable.innerHTML = state.campaigns.map((campaign) => `
        <tr>
          <td><strong>${escapeHtml(campaign.name)}</strong></td>
          <td>${escapeHtml(campaign.campaign_key)}</td>
          <td>${escapeHtml(campaign.lead_count ?? 0)}</td>
        </tr>
      `).join("");
    }

    function renderPages() {
      if (!state.pages.length) {
        pagesTable.innerHTML = `<tr><td colspan="3" class="empty">No pages yet</td></tr>`;
        return;
      }

      pagesTable.innerHTML = state.pages.map((page) => `
        <tr>
          <td><strong>${escapeHtml(page.title)}</strong></td>
          <td><a href="/${escapeHtml(page.slug)}" target="_blank">${escapeHtml(page.slug)}</a></td>
          <td>${escapeHtml(page.lead_count ?? 0)}</td>
        </tr>
      `).join("");
    }

    async function loadDashboard() {
      refreshBtn.disabled = true;
      refreshBtn.textContent = "Loading...";

      try {
        const [leadsData, campaignsData, pagesData] = await Promise.all([
          fetchJson(`${API_BASE}/api/admin/leads`),
          fetchJson(`${API_BASE}/api/admin/campaigns`),
          fetchJson(`${API_BASE}/api/admin/pages`)
        ]);

        state.leads = leadsData.leads || [];
        state.filteredLeads = state.leads;
        state.campaigns = campaignsData.campaigns || [];
        state.pages = pagesData.pages || [];

        updateStats();
        applyFilters();
        renderCampaigns();
        renderPages();
      } catch (error) {
        toast(error.message || "Unable to load dashboard", "error");
        leadsTable.innerHTML = `<tr><td colspan="8" class="empty">Error loading data</td></tr>`;
      } finally {
        refreshBtn.disabled = false;
        refreshBtn.textContent = "Refresh";
      }
    }

    function exportCsv() {
      if (!state.filteredLeads.length) {
        toast("No leads to export.", "warning");
        return;
      }

      const headers = ["id", "full_name", "email", "phone", "campaign_name", "source", "status", "created_at"];

      const rows = state.filteredLeads.map((lead) =>
        headers.map((header) => {
          const value = String(lead[header] ?? "").replaceAll('"', '""');
          return `"${value}"`;
        }).join(",")
      );

      const csv = [headers.join(","), ...rows].join("\n");
      const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");

      link.href = url;
      link.download = `liwox-leads-${new Date().toISOString().slice(0, 10)}.csv`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    }

    campaignForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const formData = new FormData(campaignForm);

      const payload = {
        name: formData.get("name"),
        campaign_key: formData.get("campaign_key"),
        description: formData.get("description"),
        status: "active"
      };

      try {
        const response = await fetch(`${API_BASE}/api/campaigns`, {
          method: "POST",
          headers: getAuthHeaders(),
          body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (!data.success) {
          throw new Error(data.error || "Unable to create campaign");
        }

        campaignForm.reset();
        toast("Campaign created successfully.");
        await loadDashboard();
      } catch (error) {
        toast(error.message || "Unable to create campaign", "error");
      }
    });

    pageForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      const formData = new FormData(pageForm);

      const payload = {
        title: formData.get("title"),
        slug: formData.get("slug"),
        page_key: formData.get("slug"),
        campaign_key: formData.get("campaign_key"),
        page_type: "landing_page",
        status: "published"
      };

      try {
        const response = await fetch(`${API_BASE}/api/pages`, {
          method: "POST",
          headers: getAuthHeaders(),
          body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (!data.success) {
          throw new Error(data.error || "Unable to create page");
        }

        pageForm.reset();
        toast("Landing page created successfully.");
        await loadDashboard();
      } catch (error) {
        toast(error.message || "Unable to create page", "error");
      }
    });

    refreshBtn.addEventListener("click", loadDashboard);
    exportBtn.addEventListener("click", exportCsv);
    searchInput.addEventListener("input", applyFilters);
    statusFilter.addEventListener("change", applyFilters);

    checkSession();
  </script>

  <style>
    .auth-shell {
      min-height: calc(100vh - 56px);
      display: grid;
      place-items: center;
      padding: 32px;
    }

    .auth-hidden,
    .dashboard-hidden {
      display: none !important;
    }

    .auth-card {
      width: min(430px, 100%);
      background: #ffffff;
      border: 1px solid var(--line);
      border-radius: 24px;
      box-shadow: var(--shadow);
      padding: 32px;
      text-align: center;
    }

    .auth-badge {
      display: inline-flex;
      padding: 6px 12px;
      border-radius: 999px;
      background: #dbeafe;
      color: #1d4ed8;
      font-size: .78rem;
      font-weight: 900;
      margin-bottom: 16px;
    }

    .auth-card h1 {
      margin: 0;
      font-size: 2rem;
      letter-spacing: -.05em;
    }

    .auth-card p {
      color: var(--muted);
      line-height: 1.6;
      margin: 12px 0 22px;
    }

    .auth-form {
      display: grid;
      gap: 12px;
    }

    .auth-form input {
      width: 100%;
      padding: 14px;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      font: inherit;
    }

    .auth-form button,
    .logout-btn,
    .sidebar-logout-btn {
      min-height: 44px;
      border: 0;
      background: var(--blue);
      color: #fff;
      border-radius: 12px;
      padding: 0 14px;
      font: inherit;
      font-weight: 900;
      cursor: pointer;
    }

    .auth-form button:disabled {
      opacity: .65;
      cursor: not-allowed;
    }

    .auth-message {
      margin-top: 14px;
      font-size: .92rem;
      line-height: 1.5;
      color: var(--muted);
    }

    .auth-message.success {
      color: #166534;
      background: #dcfce7;
      border-radius: 12px;
      padding: 12px;
    }

    .auth-message.error {
      color: #991b1b;
      background: #fee2e2;
      border-radius: 12px;
      padding: 12px;
    }

    .auth-message a {
      color: #1d4ed8;
      font-weight: 900;
    }

    .admin-topline {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: flex-start;
    }

    .logout-btn {
      background: #111827;
      white-space: nowrap;
      margin-top: 4px;
    }

    .sidebar-logout-btn {
      position: fixed;
      left: 24px;
      bottom: 24px;
      z-index: 50;
      width: 216px;
      background: rgba(255, 255, 255, 0.08);
      color: #ffffff;
      border: 1px solid rgba(255, 255, 255, 0.16);
      backdrop-filter: blur(12px);
      text-align: left;
      padding-left: 18px;
    }

    .sidebar-logout-btn:hover {
      background: rgba(239, 68, 68, 0.18);
      border-color: rgba(248, 113, 113, 0.35);
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 18px;
    }

    .metric-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 20px;
      box-shadow: var(--shadow);
    }

    .metric-card p {
      margin: 0;
      color: var(--muted);
      font-weight: 900;
      font-size: .82rem;
      text-transform: uppercase;
      letter-spacing: .05em;
    }

    .metric-card strong {
      display: block;
      margin-top: 8px;
      font-size: 2rem;
      letter-spacing: -.04em;
    }

    .toolbar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 18px;
      align-items: center;
    }

    .search-box {
      flex: 1;
      min-width: 260px;
      display: flex;
      align-items: center;
      gap: 10px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 0 14px;
      min-height: 46px;
    }

    .search-box span {
      color: var(--muted);
      font-weight: 900;
    }

    .search-box input {
      border: 0;
      outline: 0;
      width: 100%;
      font: inherit;
      background: transparent;
    }

    .toolbar select,
    .toolbar button,
    .form-grid button {
      min-height: 44px;
      border: 0;
      background: var(--blue);
      color: #fff;
      border-radius: 12px;
      padding: 0 14px;
      font: inherit;
      font-weight: 900;
      cursor: pointer;
    }

    .toolbar select {
      background: #fff;
      color: var(--text);
      border: 1px solid var(--line);
    }

    .toolbar button.secondary {
      background: #e5e7eb;
      color: #111827;
    }

    .side-stack {
      display: grid;
      gap: 18px;
    }

    .form-grid {
      display: grid;
      gap: 12px;
    }

    .field {
      width: 100%;
      padding: 13px 14px;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      font: inherit;
      background: #fff;
    }

    textarea.field {
      min-height: 90px;
      resize: vertical;
    }

    .table-wrap {
      overflow-x: auto;
    }

    .table-wrap.small table {
      min-width: 420px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 840px;
    }

    th,
    td {
      padding: 13px 12px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      font-size: .92rem;
      vertical-align: top;
    }

    th {
      background: #f9fafb;
      color: #374151;
      font-size: .78rem;
      text-transform: uppercase;
      letter-spacing: .05em;
    }

    .empty {
      text-align: center;
      color: var(--muted);
      padding: 24px;
    }

    .status-badge {
      display: inline-flex;
      padding: 5px 10px;
      border-radius: 999px;
      font-size: .78rem;
      font-weight: 900;
      background: #f3f4f6;
      color: #374151;
    }

    .status-new {
      background: #dcfce7;
      color: #166534;
    }

    .status-contacted {
      background: #dbeafe;
      color: #1d4ed8;
    }

    .status-qualified {
      background: #fef3c7;
      color: #92400e;
    }

    .status-archived {
      background: #fee2e2;
      color: #991b1b;
    }

    @media (max-width: 980px) {
      .admin-topline {
        flex-direction: column;
      }

      .kpi-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 620px) {
      .kpi-grid {
        grid-template-columns: 1fr;
      }

      .sidebar-logout-btn {
