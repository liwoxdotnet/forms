---
const {
  columns = [],
  rows = []
} = Astro.props;
---

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        {columns.map((column) => <th>{column.label}</th>)}
      </tr>
    </thead>

    <tbody>
      {rows.length ? (
        rows.map((row) => (
          <tr>
            {columns.map((column) => <td>{row[column.key] ?? ""}</td>)}
          </tr>
        ))
      ) : (
        <tr>
          <td colspan={columns.length || 1} class="empty">No records found</td>
        </tr>
      )}
    </tbody>
  </table>
</div>

<style>
  .table-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
  }

  th,
  td {
    padding: 13px 12px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    font-size: 0.92rem;
    vertical-align: top;
  }

  th {
    color: #374151;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #f9fafb;
  }

  .empty {
    text-align: center;
    color: var(--muted);
    padding: 24px;
  }
</style>
