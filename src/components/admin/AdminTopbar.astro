---
const {
  title = "Dashboard",
  description = "",
  actionText = "",
  actionHref = ""
} = Astro.props;
---

<div class="topbar">
  <div>
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </div>

  {actionText && actionHref && (
    <a class="action" href={actionHref}>{actionText}</a>
  )}
</div>

<style>
  .topbar {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    letter-spacing: -0.04em;
  }

  p {
    margin: 8px 0 0;
    color: var(--muted);
  }

  .action {
    border: 0;
    background: var(--blue);
    color: #fff;
    font-weight: 800;
    padding: 12px 16px;
    border-radius: 12px;
    cursor: pointer;
    text-decoration: none;
  }

  @media (max-width: 780px) {
    .topbar {
      flex-direction: column;
    }
  }
</style>
