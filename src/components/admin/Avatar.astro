---
const {
  name = "Liwox User",
  image = ""
} = Astro.props;

const initials = String(name)
  .split(" ")
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0]?.toUpperCase())
  .join("") || "LU";
---

<div class="avatar" title={name}>
  {image ? <img src={image} alt={name} /> : <span>{initials}</span>}
</div>

<style>
  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--blue), var(--navy));
    color: #fff;
    display: grid;
    place-items: center;
    font-weight: 900;
    overflow: hidden;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
