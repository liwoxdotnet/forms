---
const {
  title = "Section",
  description = ""
} = Astro.props;
---

<section class="dashboard-section">
  <header>
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </header>

  <slot />
</section>

<style>
  .dashboard-section {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 20px;
  }

  header {
    margin-bottom: 16px;
  }

  h2 {
    margin: 0;
    font-size: 1.25rem;
  }

  p {
    margin: 6px 0 0;
    color: var(--muted);
  }
</style>
