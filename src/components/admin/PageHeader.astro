---
const {
  title = "Page Title",
  description = "",
  buttonText = "",
  buttonHref = ""
} = Astro.props;
---

<header class="page-header">
  <div>
    <h1>{title}</h1>
    {description && <p>{description}</p>}
  </div>

  {buttonText && buttonHref && <a href={buttonHref}>{buttonText}</a>}
</header>

<style>
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 24px;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    letter-spacing: -.05em;
  }

  p {
    margin: 8px 0 0;
    color: var(--muted);
  }

  a {
    background: var(--blue);
    color: #fff;
    text-decoration: none;
    font-weight: 900;
    border-radius: 12px;
    padding: 12px 16px;
  }

  @media (max-width: 760px) {
    .page-header {
      flex-direction: column;
    }
  }
</style>
