---
const {
  eyebrow = "",
  title = "Section Title",
  description = "",
  align = "left"
} = Astro.props;
---

<header class={`section-header ${align}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {description && <p class="description">{description}</p>}
</header>

<style>
  .section-header {
    margin-bottom: 22px;
  }

  .section-header.center {
    text-align: center;
    margin-inline: auto;
  }

  .eyebrow {
    margin: 0 0 8px;
    color: var(--blue);
    font-size: 0.85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.7rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .description {
    margin: 10px 0 0;
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 720px;
  }

  .center .description {
    margin-left: auto;
    margin-right: auto;
  }
</style>
