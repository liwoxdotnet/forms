---
const {
  id = "modal",
  title = "Modal Title"
} = Astro.props;
---

<div id={id} class="modal-backdrop" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby={`${id}-title`}>
    <div class="modal-header">
      <h2 id={`${id}-title`}>{title}</h2>
      <button class="modal-close" type="button" data-close-modal={id}>×</button>
    </div>

    <div class="modal-body">
      <slot />
    </div>
  </div>
</div>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;

    if (!(target instanceof HTMLElement)) return;

    const openId = target.dataset.openModal;
    const closeId = target.dataset.closeModal;

    if (openId) {
      const modal = document.getElementById(openId);
      modal?.classList.add("active");
      modal?.setAttribute("aria-hidden", "false");
    }

    if (closeId) {
      const modal = document.getElementById(closeId);
      modal?.classList.remove("active");
      modal?.setAttribute("aria-hidden", "true");
    }

    if (target.classList.contains("modal-backdrop")) {
      target.classList.remove("active");
      target.setAttribute("aria-hidden", "true");
    }
  });
</script>

<style>
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(15, 23, 42, 0.68);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 18px;
  }

  .modal-backdrop.active {
    display: flex;
  }

  .modal-card {
    width: min(620px, 100%);
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 30px 90px rgba(0,0,0,0.24);
    overflow: hidden;
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 22px;
    border-bottom: 1px solid var(--line);
  }

  .modal-header h2 {
    margin: 0;
    font-size: 1.3rem;
    letter-spacing: -0.03em;
  }

  .modal-close {
    width: 36px;
    height: 36px;
    border: 0;
    border-radius: 999px;
    background: #f3f4f6;
    color: #111827;
    cursor: pointer;
    font-size: 1.3rem;
    line-height: 1;
  }

  .modal-body {
    padding: 22px;
  }
</style>
