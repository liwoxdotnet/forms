---
const {
  variant = "default"
} = Astro.props;

const className = `lx-badge lx-badge-${variant}`;
---

<span class={className}>
  <slot />
</span>

<style>
  .lx-badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    border-radius: 999px;
    font-weight: 900;
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .lx-badge-default {
    background: #e0f2fe;
    color: #075985;
  }

  .lx-badge-success {
    background: #dcfce7;
    color: #166534;
  }

  .lx-badge-warning {
    background: #ffedd5;
    color: #9a3412;
  }

  .lx-badge-danger {
    background: #fee2e2;
    color: #991b1b;
  }

  .lx-badge-muted {
    background: #f3f4f6;
    color: #6b7280;
  }
</style>
