---
const {
  label = "Upload File",
  name = "file",
  accept = ".pdf,.doc,.docx,.png,.jpg,.jpeg",
  required = false,
  help = "Supported files: PDF, DOC, DOCX, PNG, JPG."
} = Astro.props;
---

<label class="upload">
  <span class="label">{label}</span>

  <div class="drop">
    <strong>Choose file</strong>
    <small>{help}</small>
    <input
      type="file"
      name={name}
      accept={accept}
      required={required}
    />
  </div>
</label>

<style>
  .upload {
    display: grid;
    gap: 6px;
  }

  .label {
    font-weight: 800;
    font-size: 0.9rem;
    color: #374151;
  }

  .drop {
    position: relative;
    border: 2px dashed #cbd5e1;
    border-radius: 14px;
    padding: 22px;
    text-align: center;
    background: #f8fafc;
    cursor: pointer;
  }

  .drop:hover {
    border-color: var(--blue);
    background: #eff6ff;
  }

  strong {
    display: block;
    color: var(--blue);
    margin-bottom: 5px;
  }

  small {
    color: var(--muted);
  }

  input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
</style>
