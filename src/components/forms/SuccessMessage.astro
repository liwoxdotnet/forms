---
const {
  title = "Success",
  message = "Your submission has been received."
} = Astro.props;
---

<div class="success-message">
  <strong>{title}</strong>
  <p>{message}</p>
</div>

<style>
  .success-message {
    border-radius: 14px;
    padding: 14px 16px;
    background: #dcfce7;
    border: 1px solid #bbf7d0;
    color: #166534;
  }

  strong {
    display: block;
    margin-bottom: 4px;
  }

  p {
    margin: 0;
  }
</style>
