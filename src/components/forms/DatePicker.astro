---
const {
  label = "Date",
  name = "date",
  required = false,
  value = ""
} = Astro.props;
---

<label class="date-wrap">
  {label && <span>{label}</span>}

  <input
    type="date"
    name={name}
    required={required}
    value={value}
  />
</label>

<style>
  .date-wrap {
    display: grid;
    gap: 6px;
  }

  span {
    font-weight: 800;
    font-size: 0.9rem;
    color: #374151;
  }

  input {
    width: 100%;
    padding: 13px 14px;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    font: inherit;
    background: #fff;
  }

  input:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
  }
</style>
