---
const {
  label = "",
  name = "",
  placeholder = "",
  required = false,
  rows = 4
} = Astro.props;
---

<label class="field-wrap">
  {label && <span>{label}</span>}
  <textarea
    class="field"
    name={name}
    placeholder={placeholder}
    required={required}
    rows={rows}
  ></textarea>
</label>

<style>
  .field-wrap {
    display: grid;
    gap: 6px;
  }

  span {
    font-weight: 800;
    font-size: 0.9rem;
    color: #374151;
  }

  .field {
    width: 100%;
    padding: 13px 14px;
    border: 1px solid #d1d5db;
    border-radius: 12px;
    font: inherit;
    background: #fff;
    resize: vertical;
  }

  .field:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
  }
</style>
