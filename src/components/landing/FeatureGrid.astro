---
const {
  items = [
    { title: "Fast lead capture", description: "Every form submits directly to your D1 database." },
    { title: "Campaign tracking", description: "Know which page and source produced each lead." },
    { title: "Reusable pages", description: "Create new landing pages from shared components." }
  ]
} = Astro.props;
---

<section class="feature-section">
  <div class="grid">
    {items.map((item) => (
      <article class="feature">
        <div class="icon">✓</div>
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .feature-section {
    padding: 54px 24px;
    background: #fff;
  }

  .grid {
    width: min(1100px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .feature {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
  }

  .icon {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    background: var(--sky);
    color: var(--blue);
    display: grid;
    place-items: center;
    font-weight: 1000;
    margin-bottom: 14px;
  }

  h3 {
    margin: 0 0 8px;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
