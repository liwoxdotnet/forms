---
const {
  videoId = "",
  title = "Video",
  rounded = true
} = Astro.props;

const embedUrl = videoId
  ? `https://www.youtube.com/embed/${videoId}`
  : "";
---

<section class:list={["youtube-card", rounded && "rounded"]}>
  {
    embedUrl ? (
      <iframe
        src={embedUrl}
        title={title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      />
    ) : (
      <div class="empty-video">Video not configured</div>
    )
  }
</section>

<style>
  .youtube-card {
    width: 100%;
    overflow: hidden;
    background: #020817;
    box-shadow: 0 20px 50px rgba(2, 8, 23, 0.16);
  }

  .youtube-card.rounded {
    border-radius: 20px;
  }

  .youtube-card iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    display: block;
  }

  .empty-video {
    min-height: 260px;
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 900;
  }
</style>